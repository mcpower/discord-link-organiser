{
  "name": "girls",
  "version": "0.0.1",
  "description": "discord link organiser",
  "license": "MIT",
  "author": "mcpower",
  "main": "build/index.js",
  "scripts": {
    "start": "ts-node index.ts",
    "startProd": "tsc && node ./build/index.js",
    "debug": "node -r ts-node/register --inspect index.ts",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "test": "vitest"
  },
  "dependencies": {
    "@discordjs/builders": "1.6.x",
    "@discordjs/ws": "1.0.x",
    "@mikro-orm/better-sqlite": "5.9.x",
    "@mikro-orm/core": "5.9.x",
    "@mikro-orm/migrations": "5.9.x",
    "@mikro-orm/reflection": "5.9.x",
    "discord-api-types": "0.37.53",
    "discord.js": "14.13.x",
    "ts-node": "^10.9.1",
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@mikro-orm/cli": "5.9.x",
    "@types/node": "^18.16.0",
    "@vitest/coverage-v8": "^0.34.6",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "5.3.x",
    "vite": "^3.1.0",
    "vitest": "^0.34.6"
  },
  "engines": {
    "node": ">=16 <=20"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/orm.config.ts",
      "./build/src/orm.config.js"
    ]
  }
