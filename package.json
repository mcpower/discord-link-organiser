{
  "name": "girls",
  "version": "0.0.1",
  "description": "discord link organiser",
  "license": "MIT",
  "author": "mcpower",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "start": "ts-node index.ts",
    "startProd": "tsc && node ./build/index.js",
    "debug": "node -r ts-node/register --inspect index.ts",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "test": "vitest"
  },
  "dependencies": {
    "@discordjs/builders": "1.6.x",
    "@discordjs/ws": "1.0.x",
    "@mikro-orm/better-sqlite": "^5.9.8",
    "@mikro-orm/core": "^5.9.8",
    "@mikro-orm/migrations": "^5.9.8",
    "@mikro-orm/reflection": "^5.9.8",
    "discord.js": "14.13.x",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^5.9.8",
    "@types/node": "^18.19.130",
    "@vitest/coverage-v8": "^1.6.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "rollup": "4.20.x",
    "typescript": "5.3.x",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=16 <=20"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/orm.config.ts",
      "./build/src/orm.config.js"
    ]
  }
}
