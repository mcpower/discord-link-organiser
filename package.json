    "@mikro-orm/reflection": "^6.6.13",
    "discord.js": "~14.26.3",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.6.13",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.4",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "22"
  },
  "mikro-orm": {
